{
  "stream_name": "cloudscale-events-production",
  "consumer_config": {
    "batch_size": 100,
    "max_batching_window_seconds": 30,
    "starting_position": "LATEST",
    "parallelization_factor": 10,
    "maximum_retry_attempts": 3,
    "bisect_batch_on_error": true,
    "destination_config": {
      "on_failure": {
        "destination_arn": "arn:aws:sqs:us-east-1:ACCOUNT_ID:cloudscale-dlq"
      }
    }
  },
  "enhanced_fan_out": {
    "enabled": false,
    "consumer_name": "cloudscale-lambda-consumer"
  }
}
